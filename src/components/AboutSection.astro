---
import { Icon } from "astro-icon/components";

export interface AboutFeature {
  icon: string;
  label: string;
}

export interface AboutStat {
  value: string;
  label: string;
}

export interface AboutSectionProps {
  id?: string;
  title: string;
  description: string[];
  features: AboutFeature[];
  stats: AboutStat[];
}

const {
  id = "about",
  title = "关于贵州多彩美途",
  description = [
    "我们是贵州本地旅行社团队，专注外地游客来贵州旅行的地接接待与私家团定制。",
    "从第一次来贵州的经典路线，到亲子、摄影、避暑、商务接待，我们都会按客人的时间、预算和兴趣重新设计。",
  ],
  features = [
    { icon: "bi:geo-alt", label: "贵州本地团队" },
    { icon: "bi:award", label: "正规旅行社服务" },
  ],
  stats = [
    { value: "8+", label: "贵州核心目的地" },
    { value: "900+", label: "累计服务游客" },
    { value: "120+", label: "定制私家路线" },
    { value: "1团1策", label: "私家安排" },
  ],
} = Astro.props as AboutSectionProps;
---

<section id={id} class="relative py-16 md:py-20 bg-white overflow-hidden">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 items-center">
      <div>
        <h2 class="text-3xl md:text-4xl font-semibold text-stone-950">{title}</h2>

        {description.map((text) => (
          <p class="mt-4 text-stone-600 leading-relaxed">{text}</p>
        ))}

        <div class="mt-6 flex flex-col md:flex-row md:items-center gap-4 text-stone-700">
          {features.map((item) => (
            <div class="flex items-center gap-2">
              <Icon name={item.icon} class="w-5 h-5 text-orange-300" />
              <span>{item.label}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="grid grid-cols-2 gap-6">
        {stats.map((stat) => (
          <div class="rounded-2xl bg-orange-50 border border-orange-100 p-6">
            <div class="text-3xl font-semibold text-stone-950">{stat.value}</div>
            <div class="mt-1 text-stone-600">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
