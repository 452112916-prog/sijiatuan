---
import { Icon } from "astro-icon/components";

export interface WhyCard {
  icon: string;
  title: string;
  description: string;
}

export interface WhySectionProps {
  id?: string;
  title?: string;
  cards?: WhyCard[];
  backgroundImage?: string;
  minHeight?: string;
  className?: string;
}

const {
  id = "intro",
  title = "为什么选择多彩美途？",
  cards = [
    {
      icon: "bi:person-badge",
      title: "贵州本地司导",
      description: "熟悉景区动线、路况和季节变化，少走回头路，游玩更从容。",
    },
    {
      icon: "bi:shield-check",
      title: "正规旅行社接待",
      description: "清晰报价、规范服务，车辆、酒店、门票和时间安排提前确认。",
    },
    {
      icon: "bi:people",
      title: "私家小团体验",
      description: "只服务你和同行人，适合家庭、朋友、情侣和商务小团。",
    },
    {
      icon: "bi:leaf",
      title: "地道贵州玩法",
      description: "瀑布、喀斯特山水、苗寨侗寨、酸汤牛肉和本地集市都能安排。",
    },
    {
      icon: "bi:sliders",
      title: "行程灵活定制",
      description: "按天数、预算、体力和兴趣调整，不用被固定拼团节奏推着走。",
    },
    {
      icon: "bi:headset",
      title: "全程响应支持",
      description: "出发前协助规划，在贵州当地遇到天气或人流变化也能及时调整。",
    },
  ],
  backgroundImage = "/img/generated/xijiang-miao-village.webp",
  minHeight = "78vh",
  className = "",
} = Astro.props as WhySectionProps;
---

<section
  id={id}
  class={`relative overflow-hidden py-16 flex items-center ${className}`}
  style={`
    background-image: url('${backgroundImage}');
    background-size: cover;
    background-position: center;
    min-height: ${minHeight};
  `}
>
  <div class="absolute inset-0 bg-linear-to-b from-white/85 via-orange-50/80 to-white/95"></div>

  <div class="pointer-events-none absolute inset-0 opacity-35">
    <div class="absolute -top-20 left-1/4 h-[120%] w-44 rotate-12 bg-linear-to-b from-orange-200/25 via-orange-200/0 to-transparent blur-2xl"></div>
    <div class="absolute -top-20 left-2/3 h-[120%] w-56 -rotate-6 bg-linear-to-b from-amber-200/15 via-amber-200/0 to-transparent blur-2xl"></div>
  </div>

  <div class="relative w-full max-w-6xl mx-auto px-4 z-20">
    <h2 class="text-2xl md:text-3xl font-semibold text-stone-950 mb-6">
      {title}
    </h2>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {cards.map((card) => (
        <div class="rounded-2xl border border-orange-100 bg-white/90 p-5 shadow-sm shadow-orange-950/5 backdrop-blur">
          <div class="flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-orange-100 text-orange-600">
              <Icon name={card.icon} class="text-orange-600 text-lg w-5 h-5" />
            </div>
            <div class="text-lg font-semibold text-stone-950">{card.title}</div>
          </div>
          <div class="mt-2 text-base text-stone-600">
            {card.description}
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 h-28 bg-linear-to-t from-orange-50 to-transparent"></div>
</section>
