---
import { Icon } from "astro-icon/components";

export interface ContactSectionProps {
  id?: string;
  title?: string;
  description?: string;
  address?: string;
  email?: string;
  phone?: string;
}

const {
  id = "contact",
  title = "联系我们",
  description = "告诉我们你的抵达时间、出行人数和想去的地方，我们会帮你整理一版适合外地游客的贵州私家团方案。",
  address = "贵州省贵阳市 · 本地地接服务中心",
  email = "hello@duocaimitu.com",
  phone = "400-0851-520",
} = Astro.props as ContactSectionProps;
---

<section id={id} class="relative py-16 md:py-20 overflow-hidden">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">
      <div>
        <h2 class="text-3xl md:text-4xl font-semibold text-stone-950">{title}</h2>

        {description && (
          <p class="mt-4 text-stone-600 leading-relaxed">{description}</p>
        )}

        <div class="mt-8 space-y-5 text-stone-700">
          <div class="flex items-start gap-4">
            <div class="size-10 flex items-center justify-center rounded-xl bg-orange-500/20">
              <Icon name="bi:geo-alt" />
            </div>
            <div>
              <div class="font-semibold text-stone-950">服务区域</div>
              <div class="text-sm text-stone-600">{address}</div>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="size-10 flex items-center justify-center rounded-xl bg-orange-500/20">
              <Icon name="bi:envelope" />
            </div>
            <div>
              <div class="font-semibold text-stone-950">邮箱</div>
              <a href={`mailto:${email}`} class="text-sm text-stone-600 hover:text-orange-600">
                {email}
              </a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="size-10 flex items-center justify-center rounded-xl bg-orange-500/20">
              <Icon name="bi:telephone" />
            </div>
            <div>
              <div class="font-semibold text-stone-950">电话</div>
              <a href={`tel:${phone}`} class="text-sm text-stone-600 hover:text-orange-600">
                {phone}
              </a>
            </div>
          </div>
        </div>
      </div>

      <form
        method="post"
        class="rounded-3xl bg-white border border-orange-100 p-8 space-y-6 shadow-sm shadow-orange-950/5"
      >
        <h3 class="text-2xl font-semibold text-stone-950">留下旅行需求</h3>

        <div>
          <label class="block text-sm text-stone-600 mb-2">称呼</label>
          <input
            type="text"
            required
            placeholder="您的姓名或称呼"
            class="w-full rounded-xl bg-orange-50 border border-orange-100 px-4 py-3 text-stone-900 placeholder:text-stone-400 focus:outline-none focus:border-orange-500"
          />
        </div>

        <div>
          <label class="block text-sm text-stone-600 mb-2">联系方式</label>
          <input
            type="text"
            required
            placeholder="手机 / 微信 / 邮箱"
            class="w-full rounded-xl bg-orange-50 border border-orange-100 px-4 py-3 text-stone-900 placeholder:text-stone-400 focus:outline-none focus:border-orange-500"
          />
        </div>

        <div>
          <label class="block text-sm text-stone-600 mb-2">想法</label>
          <textarea
            rows="4"
            required
            placeholder="例如：4个人，6月从贵阳进出，想看黄果树、小七孔、西江。"
            class="w-full rounded-xl bg-orange-50 border border-orange-100 px-4 py-3 text-stone-900 placeholder:text-stone-400 focus:outline-none focus:border-orange-500"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full rounded-xl bg-orange-500 px-6 py-3 font-semibold text-white hover:bg-orange-600 transition"
        >
          发送咨询
        </button>
      </form>
    </div>
  </div>
</section>
