---
export interface TourOption {
  name: string;
  price: number;
}

export interface PackageOption {
  id: string;
  label: string;
  multiplier: number;
  description: string;
}

export interface BookingFormProps {
  tours?: TourOption[];
  packages?: PackageOption[];
  className?: string;
}

const { className = "" } = Astro.props as BookingFormProps;
---

<section class={`relative py-16 md:py-20 ${className}`}>
  <div class="mx-auto max-w-6xl px-4">
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-[1.2fr_0.8fr]">
      <div class="rounded-2xl border border-orange-100 bg-white p-6 shadow-sm shadow-orange-950/5 md:p-8">
        <p class="text-sm font-semibold text-orange-600">公司联系方式</p>
        <h2 class="mt-3 text-2xl font-semibold text-stone-950 md:text-3xl">
          贵州私家团定制咨询
        </h2>
        <p class="mt-4 max-w-2xl text-stone-600">
          需要安排贵州私家团、亲子游、包车司导、酒店建议或行程方案，可以通过电话或微信联系我们。
        </p>

        <div class="mt-8 grid gap-4 sm:grid-cols-2">
          <a
            href="tel:18984577004"
            class="rounded-2xl border border-orange-100 bg-orange-50 p-5 transition hover:border-orange-300 hover:bg-orange-100"
          >
            <span class="block text-sm text-stone-500">私人定制热线</span>
            <span class="mt-2 block text-2xl font-semibold text-stone-950">18984577004</span>
          </a>

          <a
            href="tel:4000043666"
            class="rounded-2xl border border-orange-100 bg-orange-50 p-5 transition hover:border-orange-300 hover:bg-orange-100"
          >
            <span class="block text-sm text-stone-500">官方工作电话</span>
            <span class="mt-2 block text-2xl font-semibold text-stone-950">4000043666</span>
          </a>
        </div>

        <div class="mt-6 rounded-2xl border border-orange-100 bg-stone-50 p-5">
          <h3 class="text-lg font-semibold text-stone-950">服务范围</h3>
          <div class="mt-4 grid gap-3 text-sm text-stone-600 sm:grid-cols-2">
            <span>贵州私家团定制</span>
            <span>包车司导服务</span>
            <span>亲子/长辈慢游</span>
            <span>黄果树、荔波、西江等路线咨询</span>
          </div>
        </div>
      </div>

      <aside class="rounded-2xl border border-orange-100 bg-white p-6 text-center shadow-sm shadow-orange-950/5 md:p-8">
        <p class="text-sm font-semibold text-orange-600">微信咨询</p>
        <h3 class="mt-3 text-xl font-semibold text-stone-950">扫码添加顾问</h3>
        <div class="mx-auto mt-6 max-w-[280px] rounded-2xl border border-orange-100 bg-white p-4">
          <img
            src="/img/wechat-qr.png"
            alt="贵州多彩美途微信二维码"
            class="aspect-square w-full object-contain"
            loading="eager"
          />
        </div>
        <p class="mt-5 text-sm text-stone-500">
          添加微信后请备注出行人数、计划天数和想去的景点，方便更快给出建议。
        </p>
      </aside>
    </div>
  </div>
</section>
