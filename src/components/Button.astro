---
export type ButtonVariant = "primary" | "outline" | "success" | "white";

export interface ButtonProps {
  href?: string;
  label?: string;       // ⬅️ sekarang OPTIONAL
  variant?: ButtonVariant;
  className?: string;
}

const props = Astro.props as ButtonProps;

const variant: ButtonVariant = props.variant ?? "primary";

const base =
  "inline-flex items-center justify-center rounded-xl text-sm font-semibold transition";

const variants: Record<ButtonVariant, string> = {
  primary:
    "hover:scale-110 rounded-xl bg-orange-500 hover:bg-orange-600 inline-flex items-center justify-center gap-2 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-orange-950/20 transition",
  outline:
    "hover:scale-110 rounded-xl border border-orange-300 px-6 py-3 inline-flex items-center justify-center gap-2 text-sm font-semibold text-orange-700 hover:bg-orange-50 transition",
  success:
    "hover:scale-110 rounded-xl bg-amber-600 hover:bg-amber-700 inline-flex items-center justify-center gap-2 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-orange-950/20 transition",
  white:
    "hover:scale-110 rounded-xl bg-white hover:bg-orange-50 inline-flex items-center justify-center gap-2 px-6 py-3 text-sm font-semibold text-orange-700 shadow-lg transition",
};
---

{props.href ? (
  <a
    href={props.href}
    class={`${base} ${variants[variant]} ${props.className ?? ""}`}
  >
    <slot>{props.label}</slot>
  </a>
) : (
  <button
    type="button"
    class={`${base} ${variants[variant]} ${props.className ?? ""}`}
  >
    <slot>{props.label}</slot>
  </button>
)}
