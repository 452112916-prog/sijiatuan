---
import BlogCard from "@src/components/BlogCard.astro";
import { getCollection } from "astro:content";

export interface BlogSectionProps {
  id?: string;
  title: string;
  description?: string;
  maxPosts?: number;
}

const {
  id = "blogs",
  title = "贵州旅行攻略",
  description = "路线、季节、住宿、亲子和摄影建议，帮你更轻松地规划贵州私家团。",
  maxPosts = 3,
} = Astro.props as BlogSectionProps;

const allPosts = await getCollection("blog");
const posts = allPosts.sort((a, b) => {
  const dateA =
    typeof a.data.date === "string" ? new Date(a.data.date) : a.data.date;
  const dateB =
    typeof b.data.date === "string" ? new Date(b.data.date) : b.data.date;
  return dateB.valueOf() - dateA.valueOf();
});
const visiblePosts = posts.slice(0, maxPosts);
---

<section id={id} class="relative py-16 md:py-20 overflow-hidden">
  <div class="max-w-6xl mx-auto px-4">
    <div class="mb-12 text-center">
      <h2 class="text-3xl md:text-4xl font-semibold text-stone-950">{title}</h2>
      {description && (
        <p class="mt-3 text-stone-600 max-w-2xl mx-auto">{description}</p>
      )}
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {visiblePosts.map((post) => (
        <BlogCard post={post} />
      ))}
    </div>
  </div>
</section>
