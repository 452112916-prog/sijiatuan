---
import { Icon } from "astro-icon/components";

export interface FaqItemProps {
  question: string;
  answer: string;
  open?: boolean;
}

const { question, answer, open = false } = Astro.props as FaqItemProps;
---

<div
  x-data={`{ open: ${open} }`}
  class="rounded-2xl border border-orange-100 bg-white shadow-sm shadow-orange-950/5"
>
  <button
    @click="open = !open"
    class="w-full flex items-center justify-between gap-4 p-5 text-left"
  >
    <span class="text-stone-950 font-medium">{question}</span>

    <span class="text-orange-600">
      <Icon x-show="open" name="bi:dash-lg" class="w-5 h-5" />
      <Icon x-show="!open" name="bi:plus-lg" class="w-5 h-5" />
    </span>
  </button>

  <div x-show="open" x-collapse class="px-5 pb-5 text-stone-600 leading-relaxed">
    {answer}
  </div>
</div>
