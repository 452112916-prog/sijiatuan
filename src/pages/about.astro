---
import MainLayout from "@src/layouts/MainLayout.astro";

const reviewImages = [
  "/img/reviews-watermark/fankui1.jpg",
  "/img/reviews-watermark/fankui2.jpg",
  "/img/reviews-watermark/fankui3.jpg",
  "/img/reviews-watermark/fankui4.jpg",
];

const strengths = [
  "一车一导，一家一团，全程不拼团不混团",
  "行前深度沟通，按人数、体力、预算和兴趣重排路线",
  "零购物、零隐形消费、费用包含项提前说明",
  "专属导游、旅行管家、售后专员三维服务",
  "亲子家庭、银发长辈、摄影爱好者和企业团建都可定制",
  "贵州本地团队，熟悉贵阳、安顺、黔南、黔东南、铜仁等线路节奏",
];
---

<MainLayout
  title="关于我们 - 贵州多彩美途旅行社"
  description="贵州多彩美途旅行社有限公司成立于2021年，专注贵州高端定制小团、私家团、包车司导、亲子游、银发游和企业团建接待。"
>
  <section class="relative overflow-hidden bg-orange-50 pt-32 pb-16 md:pb-20">
    <div class="absolute inset-0 bg-[url('/img/generated/xijiang-miao-village.webp')] bg-cover bg-center opacity-20"></div>
    <div class="relative mx-auto grid max-w-6xl grid-cols-1 gap-10 px-4 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
      <div>
        <p class="text-sm font-semibold text-orange-600">贵州本地品质地接社</p>
        <h1 class="mt-4 text-4xl font-semibold tracking-tight text-stone-950 md:text-5xl">
          贵州多彩美途旅行社有限公司
        </h1>
        <p class="mt-5 text-lg leading-relaxed text-stone-700">
          我们成立于2021年，扎根贵阳，专注高端定制小团、私家团和企业团建接待。多彩美途不只做线路安排，更希望成为一张鲜活的贵州名片，用细致服务把贵州山水、人文和民族风情真诚传递给每一位远道而来的客人。
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a href="/booking" class="rounded-xl bg-orange-500 px-5 py-3 font-semibold text-white shadow-lg shadow-orange-950/10 transition hover:bg-orange-600">
            联系顾问 18984577004
          </a>
          <a href="/tours" class="rounded-xl border border-orange-200 bg-white px-5 py-3 font-semibold text-orange-600 transition hover:border-orange-300 hover:bg-orange-50">
            查看私家团路线
          </a>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4">
        {[
          ["20万+", "累计服务人次"],
          ["1万+", "2025定制家庭"],
          ["99.9%", "综合好评率"],
          ["68%", "老客复购率"],
        ].map(([value, label]) => (
          <div class="rounded-2xl border border-orange-100 bg-white/90 p-6 shadow-sm shadow-orange-950/5 backdrop-blur">
            <p class="text-3xl font-semibold text-stone-950">{value}</p>
            <p class="mt-2 text-sm text-stone-500">{label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold text-orange-600">我们的服务</p>
        <h2 class="mt-3 text-3xl font-semibold text-stone-950">更适合家庭、朋友、情侣、摄影爱好者和企业小团</h2>
        <p class="mt-4 text-stone-600">
          多彩美途坚持“一家一团、独立用车、一车一导”的服务模式。行程可慢可快，酒店可舒适可精品，餐食可地道也可清淡，真正按客人的时间、体力和兴趣来安排。
        </p>
      </div>

      <div class="mt-10 grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
        {strengths.map((item) => (
          <div class="rounded-2xl border border-orange-100 bg-orange-50 p-5 text-stone-700">
            {item}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-orange-50 py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <div class="grid grid-cols-1 gap-10 lg:grid-cols-2 lg:items-center">
        <div>
          <p class="text-sm font-semibold text-orange-600">写进服务里的保障</p>
          <h2 class="mt-3 text-3xl font-semibold text-stone-950">透明、灵活、有人负责到底</h2>
          <div class="mt-6 space-y-4 text-stone-700">
            <p>行前由定制顾问深度沟通，确认抵离城市、景区偏好、酒店标准、同行成员和预算，再输出更顺路的贵州私家团方案。</p>
            <p>行程中由专属导游和旅行管家跟进，遇到天气、人流、体力变化，可以及时调整当天安排。</p>
            <p>报价、用车、住宿和包含项目提前说明，所有口头承诺尽量落实到明确方案中，让游客更安心。</p>
          </div>
        </div>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <img src="/img/certificates/aaa-credit.jpg" alt="AAA级企业信用等级证书" class="rounded-2xl border border-orange-100 bg-white object-cover shadow-sm" loading="lazy" />
          <img src="/img/certificates/aaa-service.jpg" alt="AAA级质量服务诚信单位证书" class="rounded-2xl border border-orange-100 bg-white object-cover shadow-sm" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="text-sm font-semibold text-orange-600">真实反馈</p>
          <h2 class="mt-3 text-3xl font-semibold text-stone-950">游客评价与服务口碑</h2>
        </div>
        <a href="/booking" class="text-sm font-semibold text-orange-600 hover:underline">咨询定制方案</a>
      </div>

      <div class="mt-10 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {reviewImages.map((src) => (
          <img src={src} alt="贵州多彩美途游客评价截图" class="rounded-2xl border border-orange-100 bg-white shadow-sm" loading="lazy" />
        ))}
      </div>
    </div>
  </section>
</MainLayout>
