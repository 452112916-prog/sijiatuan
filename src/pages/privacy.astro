---
import HeadingSection from "@src/components/HeadingSection.astro";
import MainLayout from "@src/layouts/MainLayout.astro";
import { getCollection, render } from "astro:content";

const entries = await getCollection("pages");
const entry = entries.find((e) => e.id.includes("privacy"));
let Content;
if (entry) {
  ({ Content } = await render(entry));
}
---

{entry ? (
  <MainLayout title={entry.data.title}>
    <HeadingSection
      title="隐私政策"
      backgroundImage="/img/optimized/bg-hero.webp"
    />
    <div class="relative py-6">
      <div class="max-w-6xl mx-auto px-4">
        <article class="post-content rounded-2xl bg-white border border-orange-100 p-6 md:p-8 shadow-sm shadow-orange-950/5">
          {Content && <Content />}
        </article>
      </div>
    </div>
  </MainLayout>
) : (
  <div>页面未找到。</div>
)}
