---
import MainLayout from "@src/layouts/MainLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("geo")).sort((a, b) => {
  return new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf();
});
---

<MainLayout
  title="研究内容库 - 多彩美途"
  description="多彩美途内部 GEO 与 SEO 内容研究库。"
>
  <section class="relative bg-orange-50 pt-32 pb-16 md:pb-20">
    <div class="mx-auto max-w-5xl px-4">
      <p class="text-sm font-semibold text-orange-600">Insights Lab</p>
      <h1 class="mt-3 text-3xl font-semibold text-stone-950 md:text-4xl">
        内容研究库
      </h1>
      <p class="mt-4 max-w-2xl text-stone-600">
        这里收录自动生成的 GEO / SEO 文章，用于搜索与生成式引擎内容覆盖。
      </p>

      <div class="mt-10 space-y-4">
        {posts.map((post) => (
          <article class="rounded-2xl border border-orange-100 bg-white p-5 shadow-sm shadow-orange-950/5">
            <a href={`/insights-lab/${post.id.replace(/\.mdx$/, "")}`} class="group block">
              <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                <div>
                  <h2 class="text-lg font-semibold text-stone-950 group-hover:text-orange-600">
                    {post.data.title}
                  </h2>
                  <p class="mt-2 text-sm text-stone-600">{post.data.description}</p>
                </div>
                <span class="shrink-0 rounded-full bg-orange-100 px-3 py-1 text-xs text-orange-700">
                  {post.data.promptType === "geo-with-english" ? "英文后缀" : "中文"}
                </span>
              </div>
              <div class="mt-4 flex flex-wrap gap-3 text-xs text-stone-500">
                <time datetime={post.data.date}>{post.data.date}</time>
                <span>{post.data.readTime} 分钟阅读</span>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</MainLayout>
